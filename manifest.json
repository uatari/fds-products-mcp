{
  "name": "fds-product-catalog-mcp",
  "version": "0.1.0",
  "purpose": "Deterministic MCP server for family-specific pricing lookup, duplicate checking, family rules, and BOM rule retrieval.",
  "entrypoint": "src/index.js",
  "runtime": {
    "language": "node",
    "transport": "stdio"
  },
  "env": {
    "required": [],
    "optional": [
      "GRIST_API_BASE_URL",
      "GRIST_DOC_ID",
      "GRIST_API_KEY",
      "GRIST_SQL_TIMEOUT_MS",
      "GRIST_RELAY_URL",
      "GRIST_RELAY_API_KEY",
      "BOM_ROOT_DIR",
      "FAMILY_RULES_DIR",
      "REQUEST_TIMEOUT_MS"
    ]
  }
}

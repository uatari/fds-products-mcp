    {
      "parameters": {
        "jsCode": "const allowedFamilies = {\n  \"vinyl-fence\": 1,\n  \"aluminum-fence\": 2,\n  \"vinyl-railing\": 3,\n  \"composite-board\": 4,\n  \"chainlink-fence\": 5,\n  \"temporary-fence\": 6\n};\n\nconst family_name = $('When Executed from MCP Trigger Call').first().json.family_name ;\n\nif (!family_name) {\n  throw new Error(\"family_name is required.\");\n}\n\nif (!allowedFamilies[family_name]) {\n  throw new Error(`Invalid family_name: ${family_name}`);\n}\n\nreturn [\n  {\n    json: {\n      query: `\n        SELECT Rules_Text\n        FROM bom_rules\n        WHERE product_family = ?\n        LIMIT 1\n      `,\n      values: allowedFamilies[family_name]\n    }\n  }\n];\n"
      },
